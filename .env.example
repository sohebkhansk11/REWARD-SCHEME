# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL URI. Encode special chars in the password (%40 for @).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres?sslmode=require

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated Vercel URLs. Set to * during initial deploy, then lock down.
ALLOWED_ORIGINS=*

# ── User Auth ─────────────────────────────────────────────────────────────────
# Random 32+ character secret for signing User JWTs (SEPARATE from admin).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
USER_JWT_SECRET=your_random_user_secret_here

# ── Admin 2FA Auth (TOTP — no external service) ───────────────────────────────
# Random 32+ character secret for signing Admin JWTs.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_JWT_SECRET=your_random_admin_secret_here

# One-time secret used to call POST /admin/auth/setup (first admin creation).
# Choose any strong random string and keep it secret.
# NOTE: No TELEGRAM_BOT_TOKEN needed — 2FA uses TOTP (Google Authenticator).
ADMIN_SETUP_SECRET=your_setup_secret_here
