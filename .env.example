# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL URI. Encode special chars in the password (%40 for @).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres?sslmode=require

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated Vercel URLs. Set to * during initial deploy, then lock down.
ALLOWED_ORIGINS=*

# ── User Auth ─────────────────────────────────────────────────────────────────
# Random 32+ character secret for signing User JWTs (SEPARATE from admin).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
USER_JWT_SECRET=your_random_user_secret_here

# ── Admin 2FA Auth (TOTP — no external service) ───────────────────────────────
# Random 32+ character secret for signing Admin JWTs.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_JWT_SECRET=your_random_admin_secret_here

# One-time secret used to call POST /admin/auth/setup (first admin creation).
# Choose any strong random string and keep it secret.
# NOTE: Admin 2FA uses TOTP (Google Authenticator) — no Telegram for 2FA.
ADMIN_SETUP_SECRET=your_setup_secret_here

# ── Developer Mode ────────────────────────────────────────────────────────────
# Set to true ONLY in staging / local environments.
# When false (or unset), ALL /dev/* endpoints return 403 — even for admins.
# NEVER set this to true in production.
ENABLE_DEV_MODE=false

# ── Broadcast — Telegram ──────────────────────────────────────────────────────
# Bot token from @BotFather. Only required for Telegram broadcast channel.
# (Not used for admin 2FA — that uses TOTP.)
# Users must have telegram_chat_id set on their profile to receive messages.
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# ── Broadcast — WhatsApp ──────────────────────────────────────────────────────
# Choose provider: twilio (default) or meta
WHATSAPP_PROVIDER=twilio

# Twilio credentials (if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# Meta Cloud API credentials (if WHATSAPP_PROVIDER=meta)
META_WHATSAPP_ACCESS_TOKEN=your_meta_bearer_token
META_PHONE_NUMBER_ID=your_phone_number_id
