# Copy this file to .env and fill in the values
# In Vercel, set these in Project → Settings → Environment Variables

# Backend URL
VITE_API_URL=https://your-backend.onrender.com

# Developer Mode — shows the hidden "Dev Tools" tab in the sidebar
# and unlocks /dev/* endpoints in the UI.
# Set to 'true' ONLY in staging. Never set this in a production Vercel deployment.
# VITE_ENABLE_DEV_MODE=true
